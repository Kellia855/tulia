# Database
DATABASE_URL=sqlite:///./tulia.db
# For PostgreSQL: postgresql+psycopg://user:password@localhost/tulia

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
FRONTEND_URL=http://localhost:5173
# Optional comma-separated additional origins
# FRONTEND_URLS=http://localhost:4173,http://127.0.0.1:5173
